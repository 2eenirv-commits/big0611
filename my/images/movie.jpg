<svg width="800" height="600" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="movieGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#e74c3c;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#c0392b;stop-opacity:1" />
    </linearGradient>
  </defs>
  <rect width="800" height="600" fill="url(#movieGradient)"/>
  <rect x="50" y="100" width="700" height="400" rx="20" fill="#fce4ec" opacity="0.9"/>
  <text x="400" y="200" font-family="Arial, sans-serif" font-size="48" fill="#2c3e50" text-anchor="middle" font-weight="bold">영화 추천 시스템</text>
  <text x="400" y="260" font-family="Arial, sans-serif" font-size="24" fill="#7f8c8d" text-anchor="middle">Movie Recommendation System</text>
  <g transform="translate(250, 300)">
    <rect x="0" y="0" width="300" height="180" rx="10" fill="#e74c3c"/>
    <polygon points="120,45 120,135 200,90" fill="#ffffff"/>
    <rect x="50" y="150" width="200" height="20" rx="5" fill="#ffffff" opacity="0.7"/>
  </g>
  <text x="400" y="480" font-family="Arial, sans-serif" font-size="18" fill="#e74c3c" text-anchor="middle">AI 기반 개인화 추천</text>
</svg>
