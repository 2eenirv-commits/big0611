<svg width="800" height="600" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="subwayGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#4a90a4;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#357a8c;stop-opacity:1" />
    </linearGradient>
  </defs>
  <rect width="800" height="600" fill="url(#subwayGradient)"/>
  <rect x="50" y="100" width="700" height="400" rx="20" fill="#e8f4f8" opacity="0.9"/>
  <text x="400" y="200" font-family="Arial, sans-serif" font-size="48" fill="#2c3e50" text-anchor="middle" font-weight="bold">지하철 데이터 분석</text>
  <text x="400" y="260" font-family="Arial, sans-serif" font-size="24" fill="#7f8c8d" text-anchor="middle">Subway Data Analysis Platform</text>
  <g transform="translate(200, 320)">
    <rect x="0" y="0" width="400" height="120" rx="10" fill="#4a90a4"/>
    <rect x="20" y="20" width="60" height="80" rx="5" fill="#ffffff"/>
    <rect x="100" y="20" width="60" height="80" rx="5" fill="#ffffff"/>
    <rect x="180" y="20" width="60" height="80" rx="5" fill="#ffffff"/>
    <rect x="260" y="20" width="60" height="80" rx="5" fill="#ffffff"/>
    <rect x="340" y="20" width="40" height="80" rx="5" fill="#ffffff"/>
  </g>
  <text x="400" y="480" font-family="Arial, sans-serif" font-size="18" fill="#4a90a4" text-anchor="middle">데이터 시각화 대시보드</text>
</svg>
