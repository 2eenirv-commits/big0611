<svg width="800" height="600" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="recipeGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#27ae60;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#1e8449;stop-opacity:1" />
    </linearGradient>
  </defs>
  <rect width="800" height="600" fill="url(#recipeGradient)"/>
  <rect x="50" y="100" width="700" height="400" rx="20" fill="#e8f5e9" opacity="0.9"/>
  <text x="400" y="200" font-family="Arial, sans-serif" font-size="48" fill="#2c3e50" text-anchor="middle" font-weight="bold">레시피 추천 앱</text>
  <text x="400" y="260" font-family="Arial, sans-serif" font-size="24" fill="#7f8c8d" text-anchor="middle">Recipe Recommendation App</text>
  <g transform="translate(300, 300)">
    <rect x="0" y="0" width="200" height="150" rx="10" fill="#27ae60"/>
    <rect x="20" y="20" width="160" height="30" rx="5" fill="#ffffff" opacity="0.8"/>
    <rect x="20" y="60" width="160" height="20" rx="5" fill="#ffffff" opacity="0.6"/>
    <rect x="20" y="90" width="160" height="20" rx="5" fill="#ffffff" opacity="0.6"/>
    <rect x="20" y="120" width="100" height="20" rx="5" fill="#ffffff" opacity="0.6"/>
  </g>
  <text x="400" y="480" font-family="Arial, sans-serif" font-size="18" fill="#27ae60" text-anchor="middle">재료 기반 맞춤 추천</text>
</svg>
